# real hardware captures -- only honest to commit an actual run, not a stand-in.
# cpx_summaries.json / cpx_events.json are derived from a (gitignored) real
# capture and are LLM-nondeterministic, so they can't be reproducible
# committed snapshots either.
data/cpx_live_run.csv
data/cpx_summaries.json
data/cpx_events.json

# Live-dashboard session history: neither a fixed-seed committed snapshot nor
# a pure real-hardware capture -- non-deterministic LLM output makes it
# unsuitable to commit either.
data/cpx_event_history.json
